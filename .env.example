# Aigenis Parser Configuration
# ============================

# --- Scraper ---
AIGENIS_BASE_URL=https://aigenis.by
AIGENIS_DATA_API_URL=
AIGENIS_HEADLESS=true
AIGENIS_USE_STEALTH=true
AIGENIS_IGNORE_HTTPS_ERRORS=false
AIGENIS_DELAY_BETWEEN_REQUESTS=2.0
AIGENIS_MAX_CONCURRENCY=2
AIGENIS_MAX_RETRIES=3
AIGENIS_TIMEOUT=30
AIGENIS_HISTORY_BACKFILL_DAYS=1825
AIGENIS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Logging ---
AIGENIS_LOG_LEVEL=INFO
AIGENIS_LOG_FILE=logs/scraper.log
AIGENIS_LOG_JSON=true
AIGENIS_LOG_ROTATION=100 MB
AIGENIS_LOG_RETENTION=14 days

# --- Sentry (optional) ---
SENTRY_DSN=
AIGENIS_ENVIRONMENT=production

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aigenis:aigenis@postgres:5432/aigenis
DATABASE_URL_SYNC=postgresql://aigenis:aigenis@postgres:5432/aigenis
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=3600
DB_SLOW_QUERY_THRESHOLD_S=0.1

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_MAX_CONNECTIONS=20

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_ADMIN_IDS=
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# --- Auth & Billing ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=price_free
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise
ADMIN_EMAIL=admin@aigenis.by
ADMIN_PASSWORD=admin123456

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aigenis.by
