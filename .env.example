# Aigenis Parser Configuration
# ============================

# --- Scraper ---
AIGENIS_BASE_URL=https://aigenis.by
AIGENIS_DATA_API_URL=
AIGENIS_HEADLESS=true
AIGENIS_USE_STEALTH=true
AIGENIS_IGNORE_HTTPS_ERRORS=false
AIGENIS_DELAY_BETWEEN_REQUESTS=2.0
AIGENIS_MAX_CONCURRENCY=2
AIGENIS_MAX_RETRIES=3
AIGENIS_TIMEOUT=30
AIGENIS_HISTORY_BACKFILL_DAYS=1825
AIGENIS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Logging ---
AIGENIS_LOG_LEVEL=INFO
AIGENIS_LOG_FILE=logs/scraper.log
AIGENIS_LOG_JSON=true
AIGENIS_LOG_ROTATION=100 MB
AIGENIS_LOG_RETENTION=14 days

# --- Sentry (optional) ---
SENTRY_DSN=
AIGENIS_ENVIRONMENT=production

# --- Database ---
# For Docker: postgresql+asyncpg://aigenis:aigenis@postgres:5432/aigenis
DATABASE_URL=sqlite+aiosqlite:///./data/aigenis.db
DATABASE_URL_SYNC=sqlite:///./data/aigenis.db
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=3600
DB_SLOW_QUERY_THRESHOLD_S=0.1

# --- Redis ---
# For Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_MAX_CONNECTIONS=20

# --- Telegram Bot ---
# REQUIRED. Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Chat ID for alerts (e.g. your own Telegram ID)
TELEGRAM_ALERT_CHAT_ID=
# Comma-separated list of admin user IDs
TELEGRAM_ADMIN_IDS=
# Webhook URL (if using webhook mode instead of polling)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# --- Auth & Billing ---
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe payments (optional — for paid subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=price_free
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise

# Crypto Pay (optional — alternative payments)
CRYPTO_SECRET_KEY=
CRYPTO_WEBHOOK_SECRET=
CRYPTO_PRICE_FREE=price_free
CRYPTO_PRICE_PRO=price_pro
CRYPTO_PRICE_ENTERPRISE=price_enterprise

# Admin credentials (created at first startup)
ADMIN_EMAIL=admin@aigenis.by
# CHANGE THIS in production
ADMIN_PASSWORD=admin123456

# --- API Server ---
FRONTEND_DIR=/app/frontend/dist
CORS_ORIGINS=*
API_RATE_LIMIT=60
API_RATE_WINDOW=60
AIGENIS_SKIP_MIGRATIONS=true

# --- Email (SMTP — optional, for password recovery etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aigenis.by
