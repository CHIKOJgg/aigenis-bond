# =============================================================================
# Aigenis Parser — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control. It is in .gitignore.
# Generate production secrets with:
#   python scripts/generate_secrets.py --write-env
# =============================================================================

# --- Scraper ---
AIGENIS_BASE_URL=https://aigenis.by
AIGENIS_WEB_URL=https://web.aigenis.by
AIGENIS_WEB_USERNAME=your_web_username
AIGENIS_WEB_PASSWORD=your_web_password
AIGENIS_HEADLESS=true
AIGENIS_USE_STEALTH=true
AIGENIS_DELAY_BETWEEN_REQUESTS=2.0
AIGENIS_MAX_CONCURRENCY=2
AIGENIS_MAX_RETRIES=3
AIGENIS_TIMEOUT=30
AIGENIS_HISTORY_BACKFILL_DAYS=1825
AIGENIS_CURRENCIES=USD,BYN,EUR,XAU,XAG,XPT
# API-mode historical quotes endpoint ({id} = internal security id). Used when
# AIGENIS_DATA_API_URL is not set. Empty disables history collection in API mode.
AIGENIS_API_HISTORY_PATH=/v1/security_history/{id}/

# --- Logging ---
AIGENIS_LOG_LEVEL=INFO
AIGENIS_LOG_FILE=logs/scraper.log
AIGENIS_LOG_JSON=true
AIGENIS_LOG_ROTATION=100 MB
AIGENIS_LOG_RETENTION=14 days

# --- Sentry (error tracking) ---
# Get DSN from https://sentry.io
SENTRY_DSN=
AIGENIS_ENVIRONMENT=production

# --- Database (PostgreSQL) ---
# Use scripts/generate_secrets.py to generate a strong password
DATABASE_URL=postgresql+asyncpg://aigenis:your_strong_password@postgres:5432/aigenis
DATABASE_URL_SYNC=postgresql://aigenis:your_strong_password@postgres:5432/aigenis
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=3600
DB_SLOW_QUERY_THRESHOLD_S=0.1

# --- Redis ---
# Use scripts/generate_secrets.py to generate a strong password
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_MAX_CONNECTIONS=20

# --- Telegram Bot ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Bot username (without @) for deep-link on subscribe page
TELEGRAM_BOT_USERNAME=your_bot_username
# Chat ID for alert notifications (optional)
TELEGRAM_ALERT_CHAT_ID=
# Comma-separated Telegram user IDs with admin access
TELEGRAM_ADMIN_IDS=
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# --- Subscription Pricing (Telegram Stars) ---
STARS_PRO=150
STARS_ENTERPRISE=500

# --- Auth ---
# Generate with: python scripts/generate_secrets.py
JWT_SECRET_KEY=your_jwt_secret_key_min_64_chars_hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth (optional) ---
# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Billing: YooKassa (ЮKassa) — карты, СБП, Apple Pay, Google Pay ---
# Получите Shop ID и Secret Key в https://yookassa.ru/merchant
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_PRO_PRICE=29.00
YOOKASSA_ENTERPRISE_PRICE=99.00
YOOKASSA_CURRENCY=BYN
# Webhook security. YooKassa does not sign webhooks: the endpoint restricts
# callers to YooKassa IP ranges and re-verifies every event via the API.
# Override the allowed source ranges only for staging (comma-separated CIDRs),
# or set to "*" to disable IP filtering (NOT recommended).
YOOKASSA_WEBHOOK_IPS=
# Set to 1 when the API runs behind a trusted reverse proxy (nginx/Cloudflare)
# so client IPs are read from the last X-Forwarded-For hop.
TRUSTED_PROXY=1

# --- Admin ---
# Use scripts/generate_secrets.py to generate a strong password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_strong_admin_password

# --- Email (SMTP) ---
# Used for verification emails, password reset, subscription notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aigenis.by

# --- Feature Flags ---
# Set RATE_LIMIT_BACKEND=redis for distributed rate limiting (requires Redis)
# Set to "memory" for single-instance deployment
RATE_LIMIT_BACKEND=redis
# Comma-separated allowed CORS origins
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com

# --- Frontend ---
# Path to built frontend static files
FRONTEND_DIR=/app/frontend/dist

# --- Docker-only: PostgreSQL ---
POSTGRES_USER=aigenis
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=aigenis

# --- Docker-only: Resource Limits ---
# Postgres
POSTGRES_MEM_LIMIT=512M
POSTGRES_MEM_RESERVE=256M
# Redis
REDIS_MAX_MEMORY=256mb
REDIS_MAXMEM_POLICY=allkeys-lru
REDIS_MEM_LIMIT=256M
REDIS_MEM_RESERVE=128M
# Parser
PARSER_MEM_LIMIT=2G
PARSER_MEM_RESERVE=1G
# Bot
BOT_MEM_LIMIT=512M
BOT_MEM_RESERVE=256M
# API
API_MEM_LIMIT=512M
API_MEM_RESERVE=256M
# Frontend
FRONTEND_MEM_LIMIT=128M
FRONTEND_MEM_RESERVE=64M

# --- Cloudflare Tunnel (optional, profile: tunnel) ---
# Public HTTPS access without port forwarding. Create a tunnel at
# dash.cloudflare.com -> Access -> Tunnels, copy the token, set it here, then:
#   docker compose --profile tunnel up -d cloudflared
# In the tunnel's Public Hostname config point your domain to:
#   Type=HTTPS, URL=frontend:443, and enable "No TLS Verify".
CLOUDFLARED_TUNNEL_TOKEN=
