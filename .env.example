AIGENIS_BASE_URL=https://aigenis.by
AIGENIS_DATA_API_URL=
AIGENIS_HEADLESS=true
AIGENIS_DELAY_BETWEEN_REQUESTS=2.0
AIGENIS_MAX_CONCURRENCY=2
AIGENIS_MAX_RETRIES=3
AIGENIS_TIMEOUT=30
AIGENIS_USE_STEALTH=true
AIGENIS_HISTORY_BACKFILL_DAYS=1825
AIGENIS_LOG_LEVEL=INFO
AIGENIS_LOG_FILE=logs/scraper.log

DATABASE_URL=postgresql+asyncpg://aigenis:aigenis@postgres:5432/aigenis
DATABASE_URL_SYNC=postgresql://aigenis:aigenis@postgres:5432/aigenis

REDIS_URL=redis://redis:6379/0

# Telegram (для алертов разработчика, опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
